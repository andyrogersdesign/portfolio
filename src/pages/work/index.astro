---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('work', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Work — Andy Rogers" description="Case studies and stories from Andy Rogers' learning design work.">
  <div class="container">
    <section class="hero">
      <h1>Work</h1>
      <p class="tagline">Thinking and execution: the problem, what I built, and the impact.</p>
    </section>

    {entries.length === 0 ? (
      <p>Case studies are on the way.</p>
    ) : (
      <ul class="cards">
        {entries.map((entry) => (
          <li class="card">
            <a
              href={entry.data.labUrl ?? `/work/${entry.id}/`}
              {...(entry.data.labUrl ? { target: '_blank', rel: 'noopener' } : {})}
            >
              <span class="theme">{entry.data.theme}</span>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.summary}</p>
              {entry.data.labUrl && <span class="card-cta">Read on the Lab →</span>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>
